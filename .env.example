COMPOSE_PROJECT_NAME=medmatrix

# Postgres config for docker-compose
POSTGRES_USER=kvision
POSTGRES_PASSWORD=kvision_secret
POSTGRES_DB=kvision_db

# Prisma connection URL (for local backend talking to postgres container on localhost:5432)
DATABASE_URL="postgresql://kvision:kvision_secret@localhost:5432/kvision_db?schema=public"

# MinIO config for docker-compose
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

REDIS_HOST=localhost
REDIS_PORT=6379
AI_SERVICE_URL=http://localhost:8000
